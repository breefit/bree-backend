# ── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000

# ── Database (MySQL) ─────────────────────────────────────────────────────────
# Pooled URL — for all app queries
DATABASE_URL="mysql://user:pass@127.0.0.1:3306/bree"

# ── JWT ───────────────────────────────────────────────────────────────────────
# Must be 64+ random chars each — NEVER share or commit
JWT_SECRET=change_me_to_a_very_long_random_string_minimum_64_characters
JWT_EXPIRES_IN=7d
ADMIN_JWT_SECRET=a_different_very_long_secret_for_admin_minimum_64_chars
ADMIN_JWT_EXPIRES_IN=1d

# ── Firebase Admin Service Account — required for verifying Google ID tokens
# Use a service account JSON credential for local development.
# If you prefer GOOGLE_APPLICATION_CREDENTIALS, set that path instead of the private key values.
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=your-firebase-service-account-email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Optional alternative for local credential discovery:
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/firebase-service-account.json

# ── Admin Seed (used by: node migrations/seed.js) ────────────────────────────
ADMIN_EMAIL=admin@bree.fit
ADMIN_PASSWORD=Change_Me_Strong_Password_123!

# ── Razorpay ─────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret_here

# ── Cloudinary ────────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_UPLOAD_FOLDER=bree-products

# ── Email (Gmail SMTP) ────────────────────────────────────────────────────────
# Use an App Password — NOT your Gmail account password
# Generate at: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=bree.fit.india@gmail.com
SMTP_PASS=your_gmail_app_password_here
